# ──────────────────────────────────────────────
# Supabase
# Project Settings → API
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# Cloudflare R2 (S3-compatible object storage)
# R2 → Manage R2 API Tokens
# ──────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=nevinfotech-portal
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
# Optional: public bucket dev URL or custom domain mapped to the bucket
R2_PUBLIC_BASE_URL=https://files.nevinfotech.example.com

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
